generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Deployment / brain-sync history, shown on the changelog page.
model ChangelogEntry {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  title       String
  description String?
  pageSlug    String?
  source      String   @default("fid")
  brainSha    String?
  createdAt   DateTime @default(now())
}

// Audit log of every autonomous enrichment write back to the brain.
// No human-approval gate — this is the record of what FID taught the brain.
model EnrichmentLog {
  id          String   @id @default(cuid())
  entityType  String   // "guru" | "product"
  entityName  String   // canonical name string
  target      String   // brain file path or Brain API kind
  summary     String?  // short description of what was written
  bytes       Int      @default(0)
  ok          Boolean  @default(true)
  error       String?
  promoCount  Int      @default(0) // how many promos were mined
  createdAt   DateTime @default(now())

  @@index([entityType, entityName])
}
