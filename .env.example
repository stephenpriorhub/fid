# ── Brain vault (git-synced markdown source) ──────────────────────────
VAULT_PATH=/data/vault
BRAIN_REPO_URL=git@github.com:PaidSites/brain.git
GITHUB_TOKEN=

# ── Database (changelog + enrichment audit log) ───────────────────────
DATABASE_URL=postgresql://

# ── OxfordHub auth ────────────────────────────────────────────────────
HUB_URL=https://oxfordhub.app
HUB_PROJECT_ID=
AUTH_SECRET=
AUTH_URL=https://fid.oxfordhub.app

# ── iSpy Emails integration ───────────────────────────────────────────
ISPY_API_URL=https://ispyemails.oxfordhub.app
ISPY_APP_URL=https://ispyemails.oxfordhub.app

# ── Promo Analyzer integration ────────────────────────────────────────
PROMO_API_URL=https://promo-analyzer.oxfordhub.app

# ── Brain API (enrichment write-back) + Anthropic ─────────────────────
BRAIN_API_URL=https://brain.oxfordhub.app
HUB_API_TOKEN=
ANTHROPIC_API_KEY=

# ── Changelog webhook ─────────────────────────────────────────────────
FID_BASE_URL=https://fid.oxfordhub.app
CHANGELOG_WEBHOOK_SECRET=
